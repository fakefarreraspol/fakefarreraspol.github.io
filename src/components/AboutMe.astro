---
interface Props {
  background?: string;
  interests?: string[];
}

const {
  background = "I am a Software Engineer specialiazed in XR technologies and 3D softwares." +
  " Currently learning about systems and backend.",
  interests = [
    "Game Development",
    "XR",
    "Open Source",
    "3D",
    "Machine Learning"
  ]
}: Props = Astro.props;
---

<section id="about" class="py-24 px-6 relative">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        <span class="text-cyan-400 font-mono text-lg mr-2">01.</span>About Me
      </h2>
      <div class="flex-1 h-px bg-gradient-to-r from-cyan-400/50 to-transparent"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-gray-300 leading-relaxed text-lg mb-6">
          {background}
        </p>
        <p class="text-gray-400 leading-relaxed">
          When I'm not working you can find me developing games or exploring new technologies.
          Or you might find me running in the field.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-white mb-6 font-mono">
          <span class="text-cyan-400">&gt;</span> Interests
        </h3>
        <div class="grid grid-cols-2 gap-3">
          {interests.map((interest) => (
            <div class="flex items-center gap-3 group">
              <span class="w-2 h-2 bg-cyan-400 rounded-full group-hover:scale-150 transition-transform"></span>
              <span class="text-gray-300 group-hover:text-cyan-400 transition-colors">{interest}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>